generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SYSTEM ──────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  operations_manager
  owner_relations
  cx_agent
  maintenance_tech
  housekeeping
  accounting
  read_only
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(read_only)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                      Account[]
  sessions                      Session[]
  auditLogs                     AuditLog[]
  assignedTickets               SupportTicket[]            @relation("AssignedTickets")
  ticketComments                TicketComment[]            @relation("TicketComments")
  notificationRules             NotificationRule[]         @relation("NotificationRulesCreated")
  watchlistEntries              NotificationWatchlist[]    @relation("WatchlistEntriesCreated")
  assignedReviews               ReviewAction[]             @relation("AssignedReviews")
  escalatedReviews              ReviewAction[]             @relation("EscalatedReviews")
  permissions                   UserPermission[]
  workspaceCred                 GoogleWorkspaceCredential?
  maintenanceExclusionsCreated  MaintenanceCostExclusion[] @relation("MaintenanceExclusionExcludedBy")
  maintenanceExclusionsRestored MaintenanceCostExclusion[] @relation("MaintenanceExclusionRestoredBy")
  maintenanceCyclesClosed       MaintenanceRechargeCycle[] @relation("MaintenanceCycleClosedBy")
  maintenanceCyclesReopened     MaintenanceRechargeCycle[] @relation("MaintenanceCycleReopenedBy")
  disputeCasesCreated           DisputeCase[]              @relation("DisputeCasesCreated")
  disputeCasesResolved          DisputeCase[]              @relation("DisputeCasesResolved")
  policyContentUpdated          PolicyContent[]            @relation("PolicyContentUpdated")
  disputeAgentConfigUpdated     DisputeAgentConfig[]       @relation("DisputeAgentConfigUpdated")
  disputeAgentVersionsCreated   DisputeAgentVersion[]      @relation("DisputeAgentVersionsCreated")
  disputeSkillsCreated          DisputeSkill[]             @relation("DisputeSkillsCreated")
  disputeKnowledgeCreated       DisputeKnowledge[]         @relation("DisputeKnowledgeCreated")
  disputeKnowledgeUpdated       DisputeKnowledge[]         @relation("DisputeKnowledgeUpdated")
  disputeKnowledgeSections      DisputeKnowledgeSection[]  @relation("DisputeKnowledgeSectionsCreated")
  disputeCaseEventsCreated      DisputeCaseEvent[]         @relation("DisputeCaseEventsCreated")
  disputeCaseTypeDefsCreated    DisputeCaseTypeDef[]       @relation("DisputeCaseTypeDefsCreated")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // CREATE | UPDATE | DELETE | LOGIN | EXPORT
  tableName String
  recordId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model WebhookLog {
  id          String    @id @default(cuid())
  source      String // guesty | breezeway | suiteop | conduit | stripe | n8n
  eventType   String
  payload     Json
  status      String    @default("received") // received | processed | failed
  errorMsg    String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([source, status])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ─── GEOGRAPHY ───────────────────────────────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  isoCode   String   @db.Char(2)
  createdAt DateTime @default(now())

  states State[]

  @@map("countries")
}

model State {
  id        String   @id @default(cuid())
  name      String
  isoCode   String?
  countryId String
  createdAt DateTime @default(now())

  country Country @relation(fields: [countryId], references: [id])
  cities  City[]

  @@map("states")
}

model City {
  id        String   @id @default(cuid())
  name      String
  stateId   String
  createdAt DateTime @default(now())

  state     State      @relation(fields: [stateId], references: [id])
  buildings Building[]

  @@map("cities")
}

// ─── BUILDINGS ───────────────────────────────────────────────────────────────

enum BuildingStatus {
  active
  inactive
  onboarding
}

model Building {
  id                String         @id @default(cuid())
  name              String
  nickname          String?
  status            BuildingStatus @default(onboarding)
  address           String?
  zone              String?
  zipcode           String?
  lat               Decimal?       @db.Decimal(10, 8)
  long              Decimal?       @db.Decimal(11, 8)
  googleUrl         String?
  website           String?
  imageUrl          String?
  floorplanUrls     String[]
  amenities         String[]
  checkinHours      String?
  checkoutHours     String?
  frontdeskHours    String?
  rules             String?        @db.Text
  emergencyContacts Json?
  knowledgeBase     String?        @db.Text
  frontdeskPhone    String?
  frontdeskEmail    String?
  cityId            String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  city             City?             @relation(fields: [cityId], references: [id])
  units            Unit[]
  propertyManagers PropertyManager[]
  contracts        OwnerContract[]
  tickets          SupportTicket[]

  @@index([status])
  @@index([cityId])
  @@map("buildings")
}

model PropertyManager {
  id             String   @id @default(cuid())
  buildingId     String
  name           String
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  contactRole    String?
  contactArea    String?
  contactMatters String?  @db.Text
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@map("property_managers")
}

// ─── OWNERS ──────────────────────────────────────────────────────────────────

enum OwnerStatus {
  active
  inactive
  churned
}

model Owner {
  id                 String      @id @default(cuid())
  nickname           String // combined display name ("First Last"), kept for lists/search
  firstName          String?
  lastName           String?
  type               String? // flexible tag (VIP, Normal, BIP, …)
  category           String?
  personality        String? // legacy free-text, retained
  personalityScore   Int? // 0–100 slider: easygoing → high-maintenance
  communicationScore Int? // 0–100 slider: low-touch → high-touch
  documentType       String?
  documentNumber     String?
  phone              String?
  address            String?     @db.Text // street line
  city               String?
  state              String?
  postalCode         String?
  country            String?
  email              String?
  otherEmail         String?
  photoUrl           String?
  linkedin           String?
  age                Int? // legacy; superseded by dateOfBirth
  dateOfBirth        DateTime?
  nationality        String?
  language           String      @default("en")
  siteUser           String?
  notes              String?     @db.Text
  status             OwnerStatus @default(active)
  inactivatedAt      DateTime? // set when status becomes inactive
  driveFolderId      String? // Google Drive folder for this owner's personal docs
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  units           Unit[]
  guestyOwners    GuestyOwner[]
  contracts       OwnerContract[]
  documents       OwnerDocument[]
  alertPrefs      OwnerDocumentAlertPref[]
  documentFolders DocumentFolder[]
  fileAlerts      FileAlert[]

  @@index([status])
  @@map("owners")
}

// Reusable, user-extensible option lists for owner dropdowns (type, category,
// language). New tags added from the form persist here so they appear next time.
model OwnerFieldOption {
  id        String   @id @default(cuid())
  field     String // "type" | "category" | "language"
  value     String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([field, value])
  @@index([field])
  @@map("owner_field_options")
}

// Raw staging mirror of every owner pulled from Guesty. `raw` holds the
// COMPLETE Guesty owner payload verbatim; the typed columns are projections.
// `ownerUniqueId` is the CONFIRMED link to a Data Master Owner; `suggestedOwnerId`
// is an auto-match candidate (by email/name) awaiting manual confirmation.
model GuestyOwner {
  id               String    @id @default(cuid())
  guestyId         String    @unique
  connectionId     String?
  fullName         String?
  accountId        String?
  email            String?
  phone            String?
  ownerType        String?
  pictureUrl       String?
  listingCount     Int?
  createdAtGuesty  DateTime?
  ownerUniqueId    String? // confirmed FK to Owner.id (many Guesty owners may map to one)
  suggestedOwnerId String? // auto-match candidate (not yet confirmed)
  mappedAt         DateTime?
  addressField9    String?
  raw              Json? // full Guesty owner payload (source of truth)
  driveFolderId    String? // Drive subfolder for this legal owner's entity docs (W-9, banking)
  syncedAt         DateTime  @default(now())

  owner      Owner?            @relation(fields: [ownerUniqueId], references: [id])
  connection GuestyConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  documents  OwnerDocument[]
  units      Unit[]

  @@index([connectionId])
  @@index([suggestedOwnerId])
  @@index([ownerUniqueId])
  @@map("guesty_owners")
}

// ─── UNITS ───────────────────────────────────────────────────────────────────

model UnitFieldOption {
  id        String   @id @default(cuid())
  field     String // "type" | "view" | "feature"
  value     String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([field, value])
  @@index([field])
  @@map("unit_field_options")
}

model Unit {
  id             String   @id @default(cuid())
  number         String
  floor          Int?
  line           String?
  view           String?
  type           String?
  bedrooms       Int?
  bathrooms      Decimal? @db.Decimal(3, 1)
  bathType       String?
  sqft           Int?
  mt2            Decimal? @db.Decimal(8, 2)
  capacity       Int?
  amenityCap     Int?
  totalBeds      Int?
  kings          Int      @default(0)
  queens         Int      @default(0)
  twins          Int      @default(0)
  otherBeds      String?
  hasKitchen     Boolean  @default(false)
  hasBalcony     Boolean  @default(false)
  features       String[]
  driveFolderUrl String?
  driveFolderId  String? // Google Drive folder for this unit's property docs
  status         String   @default("onboarding")
  score          Decimal? @db.Decimal(3, 1)
  photoQuality   String?
  notes          String?  @db.Text
  buildingId     String
  ownerUniqueId  String?
  guestyOwnerId  String? // the legal owner (LLC) that holds this unit
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building    Building             @relation(fields: [buildingId], references: [id])
  owner       Owner?               @relation(fields: [ownerUniqueId], references: [id])
  guestyOwner GuestyOwner?         @relation(fields: [guestyOwnerId], references: [id], onDelete: SetNull)
  listings        Listing[]
  contracts       OwnerContract[]
  documents       OwnerDocument[]
  inspections     UnitInspection[]
  onboarding      OnboardingChecklist?
  tickets         SupportTicket[]
  documentFolders DocumentFolder[]
  fileAlerts      FileAlert[]

  @@unique([buildingId, number])
  @@index([status])
  @@index([buildingId])
  @@index([ownerUniqueId])
  @@index([guestyOwnerId])
  @@map("units")
}

// ─── LISTINGS ────────────────────────────────────────────────────────────────

model Listing {
  id              String    @id @default(cuid())
  name            String
  guestyId        String?   @unique
  listedStatusId  String?
  groupTypeId     String?
  propertyTypeId  String?
  nickname        String?
  sqrFeet         Int?
  sqrMeter        Decimal?  @db.Decimal(8, 2)
  totalOccupancy  Int?
  activeStatusId  String?
  liveDate        DateTime?
  urlAirbnb       String?
  urlBooking      String?
  urlVrbo         String?
  urlExpedia      String?
  urlVacasa       String?
  guestyListingId String?   @unique // source GuestyListing.id when pushed from the integration
  unitId          String? // optional — a listing can exist in Data Master before being attached to a Unit
  photos          Json? // curated ListingPhoto[]: { id, kind: 'guesty'|'drive', src, order }
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  unit    Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tickets SupportTicket[]

  @@index([unitId])
  @@map("listings")
}

// ─── CONTRACTS ───────────────────────────────────────────────────────────────

model OwnerContract {
  id         String    @id @default(cuid())
  name       String
  fileUrl    String?
  startDate  DateTime?
  endDate    DateTime?
  reason     String?   @db.Text
  liveDate   DateTime?
  commission Decimal?  @db.Decimal(5, 2)
  hasLinen   Boolean   @default(false)
  dto1yr     Decimal?  @db.Decimal(5, 2)
  dto2yr     Decimal?  @db.Decimal(5, 2)
  deposit    Decimal?  @db.Decimal(10, 2)
  regFeeDate DateTime?
  accountNum String?
  routingNum String?
  hoa        Decimal?  @db.Decimal(10, 2)
  hasW9      Boolean   @default(false)
  hasFpl     Boolean   @default(false)
  buildingId String?
  unitId     String?
  ownerId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  building  Building?      @relation(fields: [buildingId], references: [id])
  unit      Unit?          @relation(fields: [unitId], references: [id])
  owner     Owner?         @relation(fields: [ownerId], references: [id])
  docs      OwnerDoc[]
  utilities OwnerUtility[]

  @@index([unitId])
  @@index([ownerId])
  @@map("owner_contracts")
}

model OwnerDoc {
  id          String    @id @default(cuid())
  code        String
  type        String?
  startDate   DateTime?
  endDate     DateTime?
  expireDate  DateTime?
  periodicity String?
  dueDate     DateTime?
  fileUrl     String?
  contractId  String
  createdAt   DateTime  @default(now())

  contract OwnerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("owner_docs")
}

model OwnerUtility {
  id            String    @id @default(cuid())
  code          String
  type          String?
  provider      String?
  startDate     DateTime?
  accountNumber String?
  monthlyCost   Decimal?  @db.Decimal(10, 2)
  contractId    String
  createdAt     DateTime  @default(now())

  contract OwnerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("owner_utilities")
}

// ─── OWNER DOCUMENTS & COMPLIANCE ALERTS ─────────────────────────────────────
// Canonical document-tracking layer. A DocumentType (e.g. contract/w9/coi) is a
// configurable catalog entry; an OwnerDocument is a concrete file that attaches
// to EITHER an owner (owner-scoped, e.g. W-9) OR a unit (unit-scoped, e.g. COI,
// Contract) and rolls up to the owner via unit.owner. Alerting is driven by a
// global DocumentAlertRule per type, optionally overridden per owner via
// OwnerDocumentAlertPref. DocumentReminderLog gives the daily cron idempotency.

enum DocScope {
  owner
  legal_owner
  unit
}

enum AlertChannel {
  slack
  email
}

// ─── SIMPLIFIED DOCUMENTS: named Drive folders + file-level renewal alerts ───
// A DocumentFolder is a named Google Drive folder attached to an owner or unit.
// An AlertType is a reusable, global renewal-alert definition (lead days + where
// to notify). A FileAlert applies an AlertType to one Drive file with its expiry.
// This supersedes the typed-document system (DocumentType/OwnerDocument/…), which
// is left dormant to avoid a destructive migration.

model DocumentFolder {
  id            String   @id @default(cuid())
  name          String // user-given label; shown as the section heading
  driveFolderId String // extracted from the pasted folder URL
  ownerId       String?
  unitId        String?
  createdAt     DateTime @default(now())

  owner      Owner?      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  unit       Unit?       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  fileAlerts FileAlert[]

  @@index([ownerId])
  @@index([unitId])
  @@map("document_folders")
}

model AlertType {
  id             String   @id @default(cuid())
  name           String // "Standard renewal (60/30/7)"
  leadTimeDays   Int[] // reminder thresholds in days-before-expiry, e.g. [60, 30, 7]
  sendHour       Int      @default(9) // hour-of-day (0–23, America/New_York) reminders send
  notifyInternal Boolean  @default(false) // internal → Slack channel
  slackChannel   String? // Slack channel human name (for display)
  slackChannelId String? // Slack channel ID (used to actually send)
  slackTemplate  String?  @db.Text // Slack message body; may contain {{variables}}
  notifyOwner    Boolean  @default(false) // external → the owner's email
  emailSubject   String? // email subject template
  emailTemplate  String?  @db.Text // email body template; may contain {{variables}}
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fileAlerts FileAlert[]

  @@map("alert_types")
}

model FileAlert {
  id             String   @id @default(cuid())
  folderId       String // -> DocumentFolder the file lives in
  driveFileId    String
  fileName       String
  expirationDate DateTime
  alertTypeId    String
  ownerId        String?
  unitId         String?
  createdAt      DateTime @default(now())

  folder    DocumentFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  alertType AlertType      @relation(fields: [alertTypeId], references: [id])
  owner     Owner?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  unit      Unit?          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  sendLogs  AlertSendLog[]

  @@index([expirationDate])
  @@index([folderId])
  @@map("file_alerts")
}

// Idempotency log for the scheduled renewal-alert sender: one row per
// (file alert, channel, lead-day threshold) that has fired, so re-runs of the
// hourly cron never double-send.
model AlertSendLog {
  id          String       @id @default(cuid())
  fileAlertId String
  channel     AlertChannel
  leadDay     Int // which offset threshold fired
  sentAt      DateTime     @default(now())
  status      String // "sent" | "skipped" | "error"
  detail      String?      @db.Text

  fileAlert FileAlert @relation(fields: [fileAlertId], references: [id], onDelete: Cascade)

  @@unique([fileAlertId, channel, leadDay])
  @@index([fileAlertId])
  @@map("alert_send_logs")
}

model DocumentType {
  key            String   @id // "contract" | "w9" | "coi" | custom
  label          String
  scope          DocScope // where the document attaches
  hasExpiry      Boolean  @default(false) // true → carries a renewal date (e.g. COI)
  required       Boolean  @default(true) // drives the "missing" computation
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  namingTemplate String? // Drive file-naming pattern, e.g. "COI - {unit} - {issueDate}"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents OwnerDocument[]
  alertRule DocumentAlertRule?

  @@map("document_types")
}

model OwnerDocument {
  id            String    @id @default(cuid())
  typeKey       String
  ownerId       String? // owner-scoped (personal: ID/passport)
  guestyOwnerId String? // legal-owner-scoped (W-9, banking) — the mapped LLC
  unitId        String? // unit-scoped (COI, Contract, HOA)
  fileUrl       String? // Drive webViewLink or external URL (or legacy GCS path)
  driveFileId   String? // Drive file id (for replace/delete); null for external links
  issueDate     DateTime?
  expireDate    DateTime? // null = no expiry (presence-only)
  notes         String?   @db.Text
  version       Int       @default(1)
  isCurrent     Boolean   @default(true) // latest version drives compliance; older kept as history
  label         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  type        DocumentType          @relation(fields: [typeKey], references: [key])
  owner       Owner?                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  guestyOwner GuestyOwner?          @relation(fields: [guestyOwnerId], references: [id], onDelete: Cascade)
  unit        Unit?                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  reminders   DocumentReminderLog[]

  @@index([ownerId])
  @@index([guestyOwnerId])
  @@index([unitId])
  @@index([typeKey])
  @@index([expireDate])
  @@index([typeKey, unitId])
  @@map("owner_documents")
}

model DocumentAlertRule {
  id                String       @id @default(cuid())
  typeKey           String       @unique
  enabled           Boolean      @default(true)
  leadTimeDays      Int[] // internal reminder thresholds, e.g. [60, 30, 7]
  notifyInternal    Boolean      @default(true)
  internalChannel   AlertChannel @default(slack) // slack | email (admin choice)
  internalTarget    String? // Slack channel id OR staff email
  notifyOwner       Boolean      @default(false) // owner reminders are always email
  ownerLeadTimeDays Int[] // owner reminder thresholds
  updatedAt         DateTime     @updatedAt

  type DocumentType @relation(fields: [typeKey], references: [key], onDelete: Cascade)

  @@map("document_alert_rules")
}

model OwnerDocumentAlertPref {
  id           String   @id @default(cuid())
  ownerId      String
  typeKey      String? // null = applies to all doc types for this owner
  muted        Boolean  @default(false) // opt this owner out entirely
  notifyOwner  Boolean? // override on/off (null = inherit)
  leadTimeDays Int[] // override thresholds (empty = inherit)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner Owner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, typeKey])
  @@index([ownerId])
  @@map("owner_document_alert_prefs")
}

model DocumentReminderLog {
  id           String       @id @default(cuid())
  documentId   String
  channel      AlertChannel
  audience     String // "owner" | "internal"
  toAddress    String?
  thresholdDay Int
  status       String // sent | failed | skipped
  sentAt       DateTime     @default(now())

  document OwnerDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_reminder_logs")
}

// ─── ONBOARDING & INSPECTIONS ────────────────────────────────────────────────

enum OnboardingStage {
  initial_contact
  contract_signed
  initial_inspection
  guesty_setup
  ota_setup
  go_live
  completed
}

model OnboardingChecklist {
  id           String          @id @default(cuid())
  unitId       String          @unique
  currentStage OnboardingStage @default(initial_contact)
  completedAt  DateTime?
  notes        String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  unit  Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tasks OnboardingTask[]

  @@map("onboarding_checklists")
}

model OnboardingTask {
  id          String          @id @default(cuid())
  checklistId String
  stage       OnboardingStage
  title       String
  description String?         @db.Text
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  isRequired  Boolean         @default(true)
  order       Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, stage])
  @@map("onboarding_tasks")
}

model UnitInspection {
  id           String    @id @default(cuid())
  unitId       String
  inspectedBy  String
  type         String    @default("initial")
  status       String    @default("draft")
  overallScore Int?
  notes        String?   @db.Text
  reportUrl    String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  unit  Unit             @relation(fields: [unitId], references: [id])
  items InspectionItem[]

  @@index([unitId])
  @@map("unit_inspections")
}

model InspectionItem {
  id           String   @id @default(cuid())
  inspectionId String
  section      String
  itemName     String
  status       String
  notes        String?
  photoUrls    String[]
  order        Int
  createdAt    DateTime @default(now())

  inspection UnitInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@map("inspection_items")
}

// ─── SUPPORT TICKETS ─────────────────────────────────────────────────────────

enum OtaSource {
  airbnb
  booking
  vrbo
  expedia
  vacasa
  other
}

enum TicketStatus {
  open
  in_progress
  pending_guest
  pending_ota
  resolved
  closed
}

model SupportTicket {
  id               String       @id @default(cuid())
  source           OtaSource
  externalId       String?
  confirmationCode String?
  guestName        String?
  guestPhone       String?
  checkinDate      DateTime?
  checkoutDate     DateTime?
  successRate      Float?
  category         String?
  status           TicketStatus @default(open)
  subject          String
  body             String       @db.Text
  fromEmail        String

  reservationId String?

  listingId  String?
  listing    Listing?  @relation(fields: [listingId], references: [id])
  unitId     String?
  unit       Unit?     @relation(fields: [unitId], references: [id])
  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  resolvedAt   DateTime?
  webhookLogId String?

  comments TicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, confirmationCode])
  @@index([status])
  @@index([source])
  @@index([confirmationCode])
  @@index([listingId])
  @@index([unitId])
  @@map("support_tickets")
}

model TicketComment {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?         @relation("TicketComments", fields: [authorId], references: [id])
  body       String        @db.Text
  isInternal Boolean       @default(false)
  source     String        @default("web")

  createdAt DateTime @default(now())

  @@map("ticket_comments")
}

// ─── RISK / CHARGEBACKS (ops-hub-owned config) ───────────────────────────────
// NOTE: The dispute/transaction data itself lives in the `risk_agent` Postgres
// schema, written by n8n. Those tables are modeled in `prisma/risk.schema.prisma`
// and consumed via the read-only `riskDb` client. The two tables below are the
// only ops-hub-owned config: alert rules and a manual guest watchlist.

model NotificationRule {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  criteria    Json // { reason?, riskLevel?, minAmountCents?, status? }
  channel     String // Slack channel id, e.g. "C098R8ZMZTL"
  priority    String   @default("normal") // normal | high | p1
  enabled     Boolean  @default(true)
  createdById String
  createdBy   User     @relation("NotificationRulesCreated", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([createdById])
  @@index([priority, createdAt(sort: Desc)])
  @@map("notification_rules")
}

model NotificationWatchlist {
  id          String   @id @default(cuid())
  email       String?
  cardLast4   String?
  lossUsd     Decimal? @db.Decimal(12, 2)
  reason      String?  @db.Text
  createdById String
  createdBy   User     @relation("WatchlistEntriesCreated", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([cardLast4])
  @@map("notification_watchlist")
}

// ─── REVIEWS (ops-hub-owned dispute workflow on top of BQ reviews) ───────────
// The review content itself lives in BigQuery (`miami-vr-data.reva_reviews.reviews`)
// and is read live with no mirror. This table is the ops-hub-side state machine:
// who is handling a review, where it sits in the dispute pipeline, the outcome,
// and (Phase 2 hook) the escalation footprint.

enum ReviewActionStatus {
  new
  under_review
  no_action
  disputing
  dispute_won
  dispute_lost
  closed_no_change
}

model ReviewAction {
  id               String             @id @default(cuid())
  otaSource        OtaSource
  externalReviewId String // BQ reviews.id — UUID v4, unique within (otaSource, externalReviewId)
  status           ReviewActionStatus @default(new)

  assignedToId String?
  assignedTo   User?   @relation("AssignedReviews", fields: [assignedToId], references: [id])

  disputeDecision    String? @db.Text // why we are (or aren't) disputing
  disputeOutcomeNote String? @db.Text // resolution detail (won/lost/closed_no_change)
  internalNotes      String? @db.Text // single free-form note in v1; threading is Phase 2

  // Phase 3 hook — populated by the n8n auto-scorer workflow against company
  // dispute policy. Read-only from the ops-hub UI until that workflow ships.
  disputeScore     Float? // 0.0–1.0 — probability of winning a dispute
  disputeAnalysis  Json? // structured payload from the AI scorer (criteria + reasoning)
  aiRecommendation String? @db.Text // human-readable verdict, e.g. "Dispute" / "Borderline" / "Don't dispute"

  // Phase 2 escalation hooks — columns created now to avoid future migrations.
  escalatedAt           DateTime?
  escalatedById         String?
  escalatedBy           User?     @relation("EscalatedReviews", fields: [escalatedById], references: [id])
  escalatedSlackChannel String?

  firstActionedAt DateTime? // set once on first transition out of `new`
  closedAt        DateTime? // set on transition into a terminal status

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([otaSource, externalReviewId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
  @@map("review_actions")
}

// ─── DISPUTE TOOL (AI adjudication: review removals + OTA disputes) ───────────
// Standalone Customer Success tool. Unlike ReviewAction (which is state on top of
// BigQuery reviews), a DisputeCase is self-contained: the agent pastes the review
// or support chat, Claude returns win-probability metrics + a verdict + an English
// support message + an evidence checklist + an English public response, and the
// case is tracked to resolution. PolicyContent is the editable OTA knowledge base.

enum DisputeCaseType {
  review // review-removal request
  disputa // OTA economic dispute
}

model DisputeCase {
  id       String    @id @default(cuid())
  // 'review' | 'disputa' (built-ins) or a custom DisputeCaseTypeDef.key.
  caseType String
  ota      OtaSource // constrained to airbnb|booking|vrbo|expedia in Zod
  // Resolved against the case type's status stages (service layer enforces it).
  status   String // default applied in the service layer per caseType

  title          String?
  guestName      String?
  reservationRef String?
  inputText      String  @db.Text // the review text or OTA support chat
  monto          String? // amount in dispute (OTA disputes only)
  cronologia     String? @db.Text // timeline (OTA disputes only)
  evidencePaths  Json? // string[] of GCS object paths; rendered via signed URLs

  probs      Json? // parsed [PROB_START]..[PROB_END] metrics (ints)
  resultText String? @db.Text // cleaned markdown analysis (verdict + messages + guide)

  // Booking context pulled from BigQuery via the reservation-code lookup:
  // { confirmationCode, reservationId, guestId, otaReservationId, property, unit,
  //   checkinDate, checkoutDate, conversationText?, reviewText? }. Fed into the AI
  // prompt and shown in the Tracker. Nullable — manual cases have none.
  reservationMeta Json?

  // Frozen structured guest conversation (ConversationMessage[]) captured at
  // create/dispute time. Makes the case a self-contained historical record so the
  // Conversation tab reads from here instead of re-querying Guesty live (which
  // could drift or be purged). Nullable — manual cases or fetch failures have none.
  conversationSnapshot Json?

  outcomeNote  String?   @db.Text // learning note captured on resolve (RAG seed — loop deferred)
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("DisputeCasesResolved", fields: [resolvedById], references: [id])

  // RESERVED for the future RAG learning loop — inert until embeddings ship.
  // Stored as Json? to avoid requiring the pgvector extension now; a real
  // `vector` column + similarity index is a deliberate later migration.
  embedding Json?

  createdById String
  createdBy   User     @relation("DisputeCasesCreated", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events DisputeCaseEvent[]

  @@index([status])
  @@index([caseType])
  @@index([ota])
  @@index([createdById])
  @@index([createdAt])
  @@map("dispute_cases")
}

// Append-only activity log for a DisputeCase: every status change and/or update
// note logged from the case detail's History tab. Captures who did what and when
// so the team can trace the case from the moment the issue arose.
model DisputeCaseEvent {
  id          String      @id @default(cuid())
  caseId      String
  case        DisputeCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  status      String // the case status as of this log entry (resolved per case type)
  note        String?     @db.Text // the free-text "Update" captured with this entry
  createdById String
  createdBy   User        @relation("DisputeCaseEventsCreated", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())

  @@index([caseId, createdAt])
  @@map("dispute_case_events")
}

// User-created case types beyond the two built-ins (review removal / OTA dispute).
// Each carries an ordered list of status stages (CaseStatusDef[] in JSON: key,
// label, tone, terminal) and the stage a new case starts in. Custom types reuse
// the generic AI analysis; built-ins stay defined in code (lib/disputes/types.ts).
model DisputeCaseTypeDef {
  id            String   @id @default(cuid())
  key           String   @unique // slug used as DisputeCase.caseType
  label         String
  statuses      Json // CaseStatusDef[]: [{ key, label, tone, terminal }]
  defaultStatus String // status key a new case of this type starts in
  sortOrder     Int      @default(0)
  createdById   String
  createdBy     User     @relation("DisputeCaseTypeDefsCreated", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("dispute_case_type_defs")
}

model PolicyContent {
  id          String    @id @default(cuid())
  ota         OtaSource // constrained to airbnb|booking|vrbo|expedia in Zod
  section     String // "review" | "general" (Zod-validated)
  contentJson Json // { review: [], general_guests: [], general_hosts: [] }
  contentHtml String    @db.Text // pre-rendered HTML for the card
  sourceUrl   String?
  updatedById String?
  updatedBy   User?     @relation("PolicyContentUpdated", fields: [updatedById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([ota, section])
  @@index([ota])
  @@map("policy_content")
}

// ─── DISPUTE AGENT (editable analysis context for the Dispute Tool) ──────────
// Configures how the analyzer "thinks": an editable identity/personality prompt
// (with simple version history), response guardrails, and scoped skills. All of
// it is appended to the Anthropic system prompt at analyze time. No memory/RAG
// here — the Agent tab's Memory section is a UI placeholder for a later pass.

model DisputeAgentConfig {
  id             String   @id @default(cuid())
  key            String   @unique @default("default") // singleton anchor
  agentName      String   @default("Dispute Adjudicator")
  identityPrompt String   @db.Text
  behaviorPrompt String   @default("") @db.Text // "Behavior & Formatting" procedural rules
  guardrails     String[]
  updatedById    String?
  updatedBy      User?    @relation("DisputeAgentConfigUpdated", fields: [updatedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("dispute_agent_config")
}

model DisputeAgentVersion {
  id             String   @id @default(cuid())
  agentName      String
  identityPrompt String   @db.Text
  behaviorPrompt String   @default("") @db.Text
  guardrails     String[]
  note           String? // e.g. "restored from <id>"
  createdById    String
  createdBy      User     @relation("DisputeAgentVersionsCreated", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@map("dispute_agent_versions")
}

model DisputeSkill {
  id           String           @id @default(cuid())
  name         String
  caseType     DisputeCaseType? // null = applies to any case type
  ota          OtaSource? // null = any OTA (constrained to the 4 in Zod)
  instructions String           @db.Text
  enabled      Boolean          @default(true)
  createdById  String
  createdBy    User             @relation("DisputeSkillsCreated", fields: [createdById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([enabled])
  @@map("dispute_skills")
}

// Tagged reference sources (OTA policies, internal notes) the analyzer can cite.
// Replaces the old PolicyContent CMS — these entries are matched by scope and
// injected into the analyze system prompt. PolicyContent is now deprecated.
model DisputeKnowledge {
  id          String                   @id @default(cuid())
  title       String
  body        String                   @db.Text
  ota         OtaSource? // null = any OTA (constrained to the 4 in Zod)
  caseType    DisputeCaseType? // null = any case type
  category    String? // optional label, e.g. "Review policy"
  sourceUrl   String?
  enabled     Boolean                  @default(true)
  // Optional custom section (a user-created OTA bucket beyond the built-in 4).
  // When set, `ota` is null. Custom-section entries are organizational only —
  // they are NOT injected into case analysis (see getRelevantKnowledge).
  sectionId   String?
  section     DisputeKnowledgeSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User                     @relation("DisputeKnowledgeCreated", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?                    @relation("DisputeKnowledgeUpdated", fields: [updatedById], references: [id])
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([enabled])
  @@index([ota, caseType])
  @@index([sectionId])
  @@map("dispute_knowledge")
}

// User-created Knowledge sections — buckets for OTAs beyond the built-in 4
// (Airbnb / Booking / Vrbo / Expedia). Organizational only: entries filed under
// a custom section are stored/displayed in the Knowledge tab but are not fed
// into case analysis (cases remain locked to the 4 built-in OTAs).
model DisputeKnowledgeSection {
  id          String             @id @default(cuid())
  label       String
  sortOrder   Int                @default(0)
  createdById String
  createdBy   User               @relation("DisputeKnowledgeSectionsCreated", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  entries     DisputeKnowledge[]

  @@map("dispute_knowledge_sections")
}

// ─── USER MANAGEMENT (RBAC + INVITATIONS) ────────────────────────────────────
// Catalog of resource keys lives in `lib/auth/resources.ts`. Each user holds
// a set of UserPermission rows (resource × view|edit). super_admin role
// bypasses the matrix and always has full access.

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  resource  String // e.g. "data_master.buildings", "customer_success.chargebacks"
  level     String // "view" | "edit"
  createdAt DateTime @default(now())
  createdBy String // userId of the admin who granted it

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource])
  @@index([userId])
  @@index([resource])
  @@map("user_permissions")
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  name        String?
  token       String    @unique // url-safe random
  permissions Json // [{ resource, level }]
  invitedBy   String // userId
  expiresAt   DateTime
  acceptedAt  DateTime?
  acceptedBy  String? // userId after sign-in
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@index([acceptedAt])
  @@map("user_invitations")
}

model GoogleWorkspaceCredential {
  id           String   @id @default(cuid())
  userId       String   @unique // admin who connected
  email        String // sender mailbox
  refreshToken String // AES-256-GCM ciphertext, base64
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_workspace_credentials")
}

// ─── MAINTENANCE REPORT MODULE ───────────────────────────────────────────────
// Owner-relations workflow state for the Maintenance Report. The Breezeway
// tasks themselves live in BigQuery (`miami-vr-data.etl_stage.parsed_breezeway_*`)
// and are read-only — these two tables capture the *decisions* the team makes
// each month about which tasks to recharge to the owner.

// One row per (taskId, periodMonth) — when a team member excludes a task from
// the recharge for a given month. Restoring sets restoredAt/restoredById
// rather than deleting, so we keep a full audit trail. Snapshots of name +
// cost are stored so the UI doesn't re-query BigQuery just to render audit.
model MaintenanceCostExclusion {
  id           String   @id @default(cuid())
  taskId       String // Breezeway task_id (INT64 in BQ, stored as string here)
  periodMonth  String // "YYYY-MM" — the recharge cycle this exclusion belongs to
  unitName     String // snapshot of Breezeway property.name at exclude time
  buildingName String? // optional snapshot
  taskTitle    String? // snapshot for audit/UI
  totalCost    Decimal? @db.Decimal(10, 2) // snapshot of the cost being excluded
  reason       String?  @db.Text // free text + dropdown choice

  excludedById String
  excludedBy   User     @relation("MaintenanceExclusionExcludedBy", fields: [excludedById], references: [id])
  excludedAt   DateTime @default(now())

  restoredById String?
  restoredBy   User?     @relation("MaintenanceExclusionRestoredBy", fields: [restoredById], references: [id])
  restoredAt   DateTime?

  @@unique([taskId, periodMonth])
  @@index([periodMonth])
  @@index([unitName, periodMonth])
  @@map("maintenance_cost_exclusions")
}

// One row per recharge cycle (YYYY-MM). Defaults to 'open'; admin can close
// it to lock further exclusion changes, then optionally reopen with a reason.
model MaintenanceRechargeCycle {
  id          String @id @default(cuid())
  periodMonth String @unique // "YYYY-MM"
  status      String @default("open") // "open" | "closed"

  closedById   String?
  closedBy     User?     @relation("MaintenanceCycleClosedBy", fields: [closedById], references: [id])
  closedAt     DateTime?
  closedReason String?

  reopenedById   String?
  reopenedBy     User?     @relation("MaintenanceCycleReopenedBy", fields: [reopenedById], references: [id])
  reopenedAt     DateTime?
  reopenedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_recharge_cycles")
}

// ─── GUESTY INTEGRATION ──────────────────────────────────────────────────────
// One row = one Guesty Open API connection. The UI treats this as a singleton
// (one company-wide connection), but the table shape leaves room for more.
// clientSecret + accessToken are AES-256-GCM ciphertext (see lib/auth/crypto.ts).
// The token is cached and reused for ~24h to respect Guesty's hard limit of
// 5 tokens per 24h per key.
model GuestyConnection {
  id             String    @id @default(cuid())
  name           String // display label, e.g. "Guesty Distribution Account"
  clientId       String // plaintext — not a secret
  clientSecret   String // AES-256-GCM ciphertext, base64
  accessToken    String? // cached bearer token, AES-256-GCM ciphertext, base64
  tokenExpiresAt DateTime? // when the cached token expires (24h after mint)
  status         String    @default("disconnected") // disconnected | connected | error
  lastError      String?   @db.Text
  lastSyncAt     DateTime?
  lastSyncCount  Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  listings GuestyListing[]
  owners   GuestyOwner[]
  syncLogs GuestySyncLog[]

  @@map("guesty_connections")
}

// Append-only activity log for Guesty operations (listing refresh, owner refresh,
// test connection). Records success and failure so the integration UI can show a
// recent-activity panel and, crucially, the reason when an operation fails.
model GuestySyncLog {
  id           String   @id @default(cuid())
  connectionId String?
  operation    String // "listing_sync" | "owner_sync" | "test_connection"
  status       String // "success" | "error"
  message      String?  @db.Text // error reason, or a short success summary
  itemCount    Int? // items processed on success
  createdAt    DateTime @default(now())

  connection GuestyConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([connectionId])
  @@map("guesty_sync_logs")
}

// Raw staging mirror of every listing pulled from Guesty. `raw` holds the
// COMPLETE Guesty payload verbatim (no field whitelist) so every refresh
// captures 100% of each listing — including any fields Guesty adds later.
// The typed columns below are projections of `raw` for fast display/search.
// `unitId` is set in Phase B when a listing is attached to a Unit.
model GuestyListing {
  id              String    @id @default(cuid())
  guestyId        String    @unique // Guesty listing _id
  connectionId    String
  title           String?
  nickname        String?
  propertyType    String? // Guesty `type`
  addressFull     String?
  accommodates    Int?
  bedrooms        Int?
  bathrooms       Decimal?  @db.Decimal(3, 1)
  active          Boolean?
  pictureUrl      String? // first picture thumbnail
  createdAtGuesty DateTime? // listing creation date in Guesty (raw.createdAt)
  raw             Json // full Guesty listing payload (source of truth)
  unitId          String? // set in Phase B when mapped to a Unit
  promoted        Boolean   @default(false) // pushed into Data Master → Listings
  promotedAt      DateTime?
  listingId       String?   @unique // the Data Master Listing created on push
  syncedAt        DateTime  @default(now())

  connection GuestyConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([unitId])
  @@index([promoted])
  @@map("guesty_listings")
}

// ─── SLACK INTEGRATION ───────────────────────────────────────────────────────
// One row = one Slack workspace connection. The UI treats this as a singleton
// (one company-wide bot), but the table shape leaves room for more. `botToken`
// is AES-256-GCM ciphertext (see lib/auth/crypto.ts), prefixed `enc:`/`raw:`
// exactly like the cached Guesty token. The token may instead be supplied via
// the SLACK_BOT_TOKEN env var, in which case the DB column is left blank and the
// env value wins (env-managed mode).
model SlackConnection {
  id            String    @id @default(cuid())
  name          String // display label, e.g. "MVR Workspace"
  botToken      String // AES-256-GCM ciphertext (enc:…|raw:…); blank when env-managed
  teamId        String? // Slack team/workspace id (from auth.test)
  teamName      String? // Slack workspace name (from auth.test)
  status        String    @default("disconnected") // disconnected | connected | error
  lastError     String?   @db.Text
  lastSyncAt    DateTime? // last channel refresh
  lastSyncCount Int? // channels pulled on the last refresh
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channels SlackChannel[]
  syncLogs SlackSyncLog[]

  @@map("slack_connections")
}

// Cached mirror of the workspace's channels, refreshed from conversations.list.
// Powers the channels table and the channel picker used by notification routing.
model SlackChannel {
  id             String   @id @default(cuid())
  slackChannelId String   @unique // Slack channel id, e.g. "C098R8ZMZTL"
  connectionId   String?
  name           String // channel name without the leading '#'
  isPrivate      Boolean  @default(false)
  isArchived     Boolean  @default(false)
  isMember       Boolean  @default(false) // whether the bot is a member
  numMembers     Int?
  syncedAt       DateTime @default(now())

  connection SlackConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([connectionId])
  @@index([name])
  @@map("slack_channels")
}

// Append-only activity log for Slack operations (channel refresh, test
// connection, test message). Mirrors GuestySyncLog so the connection UI can
// show a recent-activity panel with failure reasons.
model SlackSyncLog {
  id           String   @id @default(cuid())
  connectionId String?
  operation    String // "channel_sync" | "test_connection" | "test_message"
  status       String // "success" | "error"
  message      String?  @db.Text // error reason, or a short success summary
  itemCount    Int? // items processed on success
  createdAt    DateTime @default(now())

  connection SlackConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([connectionId])
  @@map("slack_sync_logs")
}
