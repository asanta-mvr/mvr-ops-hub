# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mvr_ops_hub"
# Cloud SQL via proxy: postgresql://user:password@/mvr_ops_hub?host=/cloudsql/miami-vr-data:us-east1:mvr-ops-hub-db

# ── AUTH ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""                  # openssl rand -base64 32

AUTH_SECRET=""                      # Same as NEXTAUTH_SECRET (Auth.js v5)

# Optional override used ONLY when constructing invitation email links. Set
# this in local dev when you want emails generated locally to point at the
# Vercel URL instead of localhost. Production can leave it unset — the code
# falls back to NEXTAUTH_URL automatically.
PUBLIC_APP_URL=""                   # e.g. https://mvr-ops-hub-git-main-asanta-mvrs-projects.vercel.app

GOOGLE_CLIENT_ID=""                 # GCP Console > APIs & Services > Credentials
GOOGLE_CLIENT_SECRET=""

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID="miami-vr-data"
GCS_BUCKET_NAME="mvr-ops-hub-assets"
GCS_SERVICE_ACCOUNT_KEY=""          # base64 -i service-account.json | tr -d '\n'

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── ANTHROPIC (Dispute Tool — server-side only, never expose to client) ───────
ANTHROPIC_API_KEY=""

# ── MONITORING ────────────────────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""                # For source map uploads

# ── INTEGRATIONS (add as each phase is developed) ─────────────────────────────
# Guesty Open API — OAuth client credentials (source of truth). Get these from
# the Guesty dashboard → API / Integrations.
GUESTY_CLIENT_ID=""                 # Phase 2+
GUESTY_CLIENT_SECRET=""             # Phase 2+

# Optional: AES-256-GCM key to encrypt the cached Guesty access token at rest in
# the DB. 32-byte hex (64 chars). If unset, the token is cached unencrypted.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_SECRET_KEY=""           # Phase 2+ (recommended)

# Inbound Guesty webhook receiver (Phase B).
GUESTY_WEBHOOK_SECRET=""

BREEZEWAY_API_KEY=""                # Phase 4
BREEZEWAY_WEBHOOK_SECRET=""

STRIPE_SECRET_KEY=""                # Phase 3
STRIPE_WEBHOOK_SECRET=""

BRIVO_CLIENT_ID=""                  # Phase 4
BRIVO_CLIENT_SECRET=""

SLACK_BOT_TOKEN=""                  # xoxb-… bot token (keep real value only in .env.local)
SLACK_SIGNING_SECRET=""

N8N_API_URL="https://service.mvr-management.com/"                      # Phase 6
N8N_API_KEY=""                      # n8n public API JWT (real value only in .env.local)

SUITEOP_WEBHOOK_SECRET=""           # Phase 4
CONDUIT_WEBHOOK_SECRET=""           # Phase 2

# ── REVIEWS WEEKLY BRIEF (PDF endpoint called by n8n) ────────────────────────
# Shared bearer token for /api/v1/reviews/weekly-brief and the matching
# preview page. Same value must be set in n8n env so the cron HTTP Request
# node can authenticate. Generate with: openssl rand -hex 32
WEEKLY_BRIEF_TOKEN=""
# Optional — when running locally, point puppeteer-core at your installed
# Chrome (the @sparticuz/chromium bundle is Linux-only for Vercel runtime).
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=""

# ── RISK / CHARGEBACKS ────────────────────────────────────────────────────────
# Read-only Postgres URL to the risk_agent schema (separate user from DATABASE_URL).
# Use mvr_risk_reader role in production; grant SELECT only on risk_agent.*
RISK_DATABASE_URL=""
# n8n webhook that ops hub POSTs to when a user clicks "Alert Selected".
N8N_NOTIFICATION_WEBHOOK_URL=""
N8N_WEBHOOK_SIGNING_SECRET=""       # HMAC secret shared with n8n consumer

# ── Email via Gmail SMTP (used for /settings/users invitations) ───────────
# Setup (one-time, per Google Workspace account):
#   1) Make sure 2-Step Verification is ON for the sender account.
#      https://myaccount.google.com/security
#   2) Create an App Password:  https://myaccount.google.com/apppasswords
#      Choose "Mail" → "Other (custom name)" → "MVR-OS".
#      Google returns 16 chars (formatted "xxxx xxxx xxxx xxxx"); paste
#      WITHOUT the spaces into SMTP_PASSWORD.
#   3) Mirror these vars in Vercel → Project → Settings → Environment
#      Variables for Production (and Preview if desired).
# If any of HOST/PORT/USER/PASSWORD is missing, the app still works but
# invitations are NOT emailed (the link can be copy-pasted manually).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=a.santa@miamivacationrentals.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_FROM_NAME=MVR-OS

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for the scheduled renewal-alert sender. Vercel Cron sends it as
# `Authorization: Bearer $CRON_SECRET`; the route rejects any other caller. Set
# the same value in Vercel project env. Generate: `openssl rand -hex 32`.
CRON_SECRET=replace-with-a-long-random-string
