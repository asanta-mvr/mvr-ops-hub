    {
      "id": "txt-151",
      "type": "text",
      "x": 1200,
      "y": 805,
      "width": 366.3,
      "height": 22.5,
      "angle": 0,
      "strokeColor": "#2D6A4F",
      "backgroundColor": "transparent",
