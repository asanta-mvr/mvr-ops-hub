# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# tool artifacts (MCP session logs, etc.)
*.log

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
/lib/generated/risk-client

# n8n workflow JSON snapshots — local-only safety backups
/n8n-snapshots

# Notion owner/unit export — contains owner PII (names, emails, phones)
/prisma/notion-units.csv

# Design-inspiration mockups — only the README is versioned
/web_apps_examples/*
!/web_apps_examples/README.md
