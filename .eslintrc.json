{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "ignorePatterns": [
    "lib/generated/**",
    "node_modules/**",
    ".next/**"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_"
    }],
    "@next/next/no-img-element": "off"
  }
}
