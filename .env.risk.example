# ═══════════════════════════════════════════════════════════════════════
# MVR Risk Agent — environment template
# ─────────────────────────────────────────────────────────────────────
# Copy to .env.risk.local and fill in real values. Never commit the .local file.
#
# Consumed by:
#   - lib/db/risk.ts (Prisma client for the risk_agent schema)
#   - scripts/* (verify-2026-totals, check-risk-freshness, inspect-stripe-events, etc.)
#   - prisma/risk.schema.prisma (db pull / generate)
#
# This is a SEPARATE environment from .env.local. The risk agent connects to
# the same Cloud SQL instance but as a different user (`risk_agent_writer`)
# scoped to the `risk_agent` schema, which is a read-mostly mirror populated
# by n8n. The main app (.env.local) uses `mvr_app_user` against `public`.
# ═══════════════════════════════════════════════════════════════════════

# ─── Google Cloud / Cloud SQL ──────────────────────────────────────────
GCP_PROJECT_ID="miami-vr-data"
GCP_REGION="us-east1"
GCS_BUCKET_NAME="mvr-ops-hub-assets"

# Service account: mvr-app-service@miami-vr-data.iam.gserviceaccount.com
# Format: base64-encoded JSON of the key file.
# To decode for local use:  echo $GCS_SERVICE_ACCOUNT_KEY | base64 -d > sa-key.json
GCS_SERVICE_ACCOUNT_KEY=""

# Cloud SQL — Postgres instance
CLOUDSQL_INSTANCE_CONNECTION_NAME="miami-vr-data:us-east1:mvr-ops-hub-db"
DATABASE_SCHEMA="risk_agent"
DATABASE_NAME="mvr_ops_hub"
DATABASE_USER="risk_agent_writer"
# ⚠ Password may contain special chars — URL-encode when embedding in DATABASE_URL.
DATABASE_PASSWORD=""
DATABASE_HOST="127.0.0.1"   # via Cloud SQL Auth Proxy
DATABASE_PUBLIC_IP="34.26.178.62"
DATABASE_PORT="5432"
# Format: postgresql://USER:URL_ENCODED_PWD@127.0.0.1:5432/mvr_ops_hub?options=-csearch_path%3Drisk_agent
DATABASE_URL=""

# ─── n8n (self-hosted) ─────────────────────────────────────────────────
N8N_BASE_URL="https://service.mvr-management.com"
N8N_API_KEY=""
# Workflow shell that ingests Stripe events
N8N_INGEST_WORKFLOW_ID=""

# ─── Stripe ────────────────────────────────────────────────────────────
# Recommended: Restricted Key, not the master secret key
STRIPE_API_MODE="test"             # test | live
STRIPE_SECRET_KEY=""               # rk_test_... (restricted key)
STRIPE_PUBLISHABLE_KEY=""          # pk_test_... (only if dashboard does client-side calls)
STRIPE_WEBHOOK_SECRET=""           # whsec_... (from the registered webhook endpoint)
STRIPE_WEBHOOK_PATH="/webhook/stripe/ingest"

# ─── Slack ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=""                 # not needed when n8n uses OAuth credential
SLACK_OPS_CHANNEL="test-ti"
SLACK_OPS_CHANNEL_ID=""
SLACK_ONCALL_USER_GROUP=""         # subteam handle for P1 @-mentions

# ─── App config ────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="info"
